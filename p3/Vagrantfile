Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"
  config.vm.hostname = 'TestMachine'
  config.vm.provider "virtualbox" do |v|
    v.name = "TestMachine"
    v.memory = 4096
    v.cpus = 4
  end
  config.vm.network "private_network", ip: "192.168.56.112"
  # FIX: added provisioner so script runs on vagrant up
  config.vm.provision "shell", path: "scripts/instalation.sh", args: ["-u"]
end